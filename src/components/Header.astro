---
---
<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="px-8 md:px-16 lg:px-24 py-6 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="group">
      <span id="nav-logo" class="text-subtitle text-white group-hover:opacity-70 transition-colors duration-500 tracking-[0.2em]">
        Kate Voet
      </span>
    </a>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center gap-10">
      <a href="/" id="nav-work" class="text-subtitle text-white/70 hover:opacity-100 transition-colors duration-500 link-underline">
        Work
      </a>
      <a href="/about/" id="nav-about" class="text-subtitle text-white/70 hover:opacity-100 transition-colors duration-500 link-underline">
        About
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden text-white/80 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-charcoal/95 backdrop-blur-sm">
    <div class="px-8 py-8 flex flex-col gap-6">
      <a href="/" class="text-subtitle text-white/70 hover:text-white transition-colors">Work</a>
      <a href="/about/" class="text-subtitle text-white/70 hover:text-white transition-colors">About</a>
    </div>
  </div>
</header>

<script>
  function initNav() {
    const header = document.getElementById('site-header');
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const logo = document.getElementById('nav-logo');
    const navWork = document.getElementById('nav-work');
    const navAbout = document.getElementById('nav-about');

    function setNavLight() {
      logo.classList.replace('text-charcoal', 'text-white');
      navWork.classList.replace('text-charcoal/70', 'text-white/70');
      navAbout.classList.replace('text-charcoal/70', 'text-white/70');
      mobileBtn.classList.replace('text-charcoal/80', 'text-white/80');
    }

    function setNavDark() {
      logo.classList.replace('text-white', 'text-charcoal');
      navWork.classList.replace('text-white/70', 'text-charcoal/70');
      navAbout.classList.replace('text-white/70', 'text-charcoal/70');
      mobileBtn.classList.replace('text-white/80', 'text-charcoal/80');
    }

    function updateNav() {
      if (window.scrollY > window.innerHeight * 0.8) {
        setNavDark();
      } else {
        setNavLight();
      }
    }

    // Apply correct state immediately on every page load / navigation
    updateNav();

    // Scroll listener — throttled via requestAnimationFrame
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateNav();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // Mobile menu toggle
    mobileBtn?.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }

  // Run on first load and after every Astro view-transition navigation
  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
