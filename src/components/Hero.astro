---
import { Image } from 'astro:assets';
import heroImg from '../assets/img/thetearsofthings/stills/TTOT_20212101_1.1.134.png';
---
<section class="relative h-screen w-full overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImg}
      alt="Film still from The Tears of Things, directed by Kate Voet"
      class="w-full h-full object-cover"
      style="object-position: 30% 50%"
      widths={[800, 1200, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/60"></div>
  </div>

  <!-- Grain Overlay — static tiled texture, no per-frame GPU filter cost -->
  <div class="grain-overlay absolute inset-0 z-10" style="opacity: 0.15;"></div>

  <!-- Content -->
  <div class="relative z-20 h-full flex flex-col justify-end pb-24 md:pb-32 px-8 md:px-16 lg:px-24">
    <div class="max-w-4xl">
      <p class="text-subtitle text-white/70 mb-4 animate-fade-in opacity-0">
        Film Director & Screenwriter
      </p>
      <h1 class="text-display text-white mb-6 animate-fade-in-up opacity-0 delay-200">
        Kate Voet
      </h1>
      <p class="font-light text-base leading-loose text-white max-w-lg mb-8 animate-fade-in opacity-0 delay-500">
        Crafting intimate stories that explore memory, connection, and the spaces between us.
      </p>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-fade-in opacity-0 delay-1000">
    <div class="flex flex-col items-center gap-2">
      <span class="text-caption text-white/50">Scroll</span>
      <div class="w-px h-12 bg-white/30 relative overflow-hidden">
        <div class="w-full h-1/2 bg-white/80 absolute top-0 animate-[slideDown_2s_ease-in-out_infinite]"></div>
      </div>
    </div>
  </div>

  <style>
    @keyframes slideDown {
      0% { transform: translateY(-100%); }
      50% { transform: translateY(100%); }
      100% { transform: translateY(100%); }
    }
  </style>
</section>
