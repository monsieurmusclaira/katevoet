---
import { Image } from 'astro:assets';
const { synopsis, title, heroImage, imageposition, alt } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/img/**/*.{png,jpg,jpeg,webp,avif,gif}'
);
const imageKey = `/src/assets${heroImage}`;
const imageImport = allImages[imageKey];
const resolvedImage = imageImport ? (await imageImport()).default : null;
---
<div class="h-screen w-full relative" data-aos="fade-down" data-aos-duration="300">
    <div class="z-0 h-screen w-full absolute top-0">
        {resolvedImage
          ? <Image
              src={resolvedImage}
              alt={alt}
              class="w-full h-full object-cover"
              style={`object-position: ${imageposition || '50% 50%'}`}
              widths={[800, 1200, 1920]}
              sizes="100vw"
              loading="eager"
              fetchpriority="high"
              decoding="sync"
            />
          : <img
              src={heroImage}
              alt={alt}
              class="w-full h-full object-cover"
              style={`object-position: ${imageposition || '50% 50%'}`}
              loading="eager"
              fetchpriority="high"
              decoding="sync"
            />
        }
    </div>

    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/70"></div>

    <!-- Grain Overlay — static tiled texture, no per-frame GPU filter cost -->
    <div class="grain-overlay absolute top-0 z-10 w-full h-full" style="opacity: 0.12;"></div>

    <div class="z-10 w-full bottom-0 pt-20 pb-10 absolute text-white overflow-hidden">
        <div class="prose text-center pt-20 px-10 mx-auto max-w-3xl">
            <p class="text-subtitle text-white mb-4">{title}</p>
            <p class="drop-in-2 text-white text-lg md:text-xl max-w-2xl mx-auto leading-relaxed font-montserrat font-normal">{synopsis}</p>
            <div class="drop-in-3 flex justify-center items-center py-6">
                <svg width="20" height="20" viewBox="0 0 15 15" class="animate-bounce fill-white/60" xmlns="http://www.w3.org/2000/svg">
                    <path d="M7.5 2C7.77614 2 8 2.22386 8 2.5L8 11.2929L11.1464 8.14645C11.3417 7.95118 11.6583 7.95118 11.8536 8.14645C12.0488 8.34171 12.0488 8.65829 11.8536 8.85355L7.85355 12.8536C7.65829 13.0488 7.34171 13.0488 7.14645 12.8536L3.14645 8.85355C2.95118 8.65829 2.95118 8.34171 3.14645 8.14645C3.34171 7.95118 3.65829 7.95118 3.85355 8.14645L7 11.2929L7 2.5C7 2.22386 7.22386 2 7.5 2Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
                </svg>
            </div>
        </div>
    </div>
</div>
